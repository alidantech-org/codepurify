{
  "name": "codepot-openapi",
  "version": "0.0.10",
  "description": "Typed OpenAPI contract engine for TypeScript projects.",
  "type": "module",
  "homepage": "https://code.alidantech.org/",
  "repository": {
    "type": "git",
    "url": "https://github.com/alidantech-org/codepurify.git",
    "directory": "packages/nodejs/openapi"
  },
  "bugs": {
    "url": "https://github.com/alidantech-org/codepurify/issues"
  },
  "author": {
    "name": "AlidanTech",
    "url": "https://alidantech.org"
  },
  "license": "MIT",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsup --watch",
    "build": "pnpm clean && tsup",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev:build": "pnpm build",
    "pack:dry": "pnpm build && pnpm typecheck && npm pack --dry-run",
    "prepublishOnly": "pnpm build && pnpm typecheck"
  },
  "dependencies": {
    "@apidevtools/swagger-parser": "^10.1.1",
    "@redocly/cli": "^2.31.3",
    "chalk": "^5.4.1",
    "esbuild": "^0.25.12",
    "js-yaml": "^4.1.0",
    "ora": "^8.2.0",
    "picocolors": "^1.1.1",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.22.3",
    "typescript": "^5.0.0",
    "zod": "^4.0.0"
  },
  "peerDependencies": {
    "zod": "^4.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "openapi",
    "openapi-3",
    "typescript",
    "zod",
    "codegen",
    "sdk",
    "cli",
    "contract"
  ],
  "bin": {
    "codepot-openapi": "./dist/cli/index.js"
  }
}
