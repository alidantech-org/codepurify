{
  "name": "codepot",
  "version": "0.1.2-beta",
  "description": "Semantic metadata inference engine + template compiler for generating architecture artifacts from typed domain configs",
  "type": "module",
  "homepage": "https://code.alidantech.org/",
  "repository": {
    "type": "git",
    "url": "https://github.com/alidantech-org/codepurify.git"
  },
  "bugs": {
    "url": "https://github.com/alidantech-org/codepurify/issues"
  },
  "author": {
    "name": "AlidanTech",
    "url": "https://alidantech.org"
  },
  "bin": {
    "codepot": "./dist/cli.js"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsup --watch",
    "clean": "shx rm -rf dist",
    "copy:examples": "shx mkdir -p dist && shx rm -rf dist/examples && shx cp -r examples dist/",
    "build": "npm run clean && tsup && npm run copy:examples",
    "build:bundle": "tsup",
    "watch": "npm run copy:examples && tsup --watch --onSuccess \"npm run copy:examples\"",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write .",
    "prepublishOnly": "npm run build && npm run typecheck",
    "codepot:build": "tsx cli/index.ts build",
    "codepot:dry": "tsx cli/index.ts build --dry-run",
    "codepot:inspect": "tsx cli/index.ts inspect",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:smoke": "vitest run tests/smoke",
    "test:unit": "vitest run tests/unit"
  },
  "dependencies": {
    "@apidevtools/swagger-parser": "^10.1.1",
    "@clack/prompts": "^1.3.0",
    "@redocly/cli": "^2.31.3",
    "chalk": "^5.4.1",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "consola": "^3.4.2",
    "esbuild": "^0.28.0",
    "eta": "^3.5.0",
    "execa": "^9.3.0",
    "fast-glob": "^3.3.2",
    "fs-extra": "^11.2.0",
    "jiti": "^2.6.1",
    "js-yaml": "^4.1.1",
    "ora": "^9.4.0",
    "picocolors": "^1.1.1",
    "ts-morph": "^23.0.0",
    "yaml": "^2.7.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.14.10",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "eslint": "^9.6.0",
    "prettier": "^3.3.2",
    "shx": "^0.4.0",
    "tsc-alias": "^1.8.8",
    "tsup": "^8.1.0",
    "tsx": "^4.22.3",
    "typescript": "^5.5.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "nestjs",
    "generator",
    "codegen",
    "typescript",
    "cli"
  ],
  "license": "MIT"
}