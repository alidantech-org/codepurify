{% for import in operation.imports %}
{{ import.rendered }}
{% endfor %}

export interface {{ operation.name.class_name }}Input {
{% if operation.input.params_type %}
  params: {{ operation.input.params_type.annotation }};
{% endif %}
{% if operation.input.query_type %}
  query: {{ operation.input.query_type.annotation }};
{% endif %}
{% if operation.input.body_type %}
  body: {{ operation.input.body_type.annotation }};
{% endif %}
}

export type {{ operation.name.class_name }}Result =
  {% if operation.output.result_type %}{{ operation.output.result_type.annotation }}{% else %}void{% endif %};
