import { Controller } from '@nestjs/common';
import { {{ resource.name.pascal }}Service } from './{{ resource.name.path.o }}.service';

@Controller('{{ resource.path | csv | replace(", ", "/") }}')
export class {{ resource.name.pascal }}Controller {
  constructor(private readonly {{ resource.name.camel }}Service: {{ resource.name.pascal }}Service) {}

{%- for operation in resource.operations %}
