export 'client.dart';
export 'routes/routes.dart';

{% for model in schemas.emit_models %}
export 'schemas/{{ model.emit.resource_path | join("/") }}/models/{{ model.name.path.o }}/index.dart';{{ "\n" }}
{% endfor %}

{% for enum in schemas.emit_enums %}
export 'schemas/{{ enum.emit.resource_path | join("/") }}/enums/{{ enum.name.path.o }}/index.dart';{{ "\n" }}
{% endfor %}

{% for dto in schemas.emit_dtos %}
export 'schemas/{{ dto.emit.resource_path | join("/") }}/dtos/{{ dto.name.path.o }}/index.dart';{{ "\n" }}
{% endfor %}

{% for resource in features %}
export 'features/{{ resource.name.path.o }}_feature.dart';{{ "\n" }}
{% endfor %}
