{% macro params_props(operation) -%}
{% for param in operation.meta.path_params %}
  {{ param }}: string;
{% endfor %}
{%- endmacro %}
{% macro params_object(operation, owner='props') -%}
{% if operation.meta.has_path_params %}
    params: {
{% for param in operation.meta.path_params %}
      {{ param }}: {{ owner }}.{{ param }},
{% endfor %}
    },
{% endif %}
{%- endmacro %}
{% set ui = namespace(list=None, create=None) %}
{% for operation in resource.operations %}
{% if operation.meta.ui_enabled and operation.meta.ui_role == "list" and operation.meta.ui_list_field and operation.meta.ui_list_item_type %}
{% set ui.list = operation %}
{% elif operation.meta.ui_enabled and operation.meta.ui_role == "create" %}
{% set ui.create = operation %}
{% endif %}
{% endfor %}
{% if ui.list %}
import { {{ ui.list.lang.function_name }} } from '@/lib/server/actions/{{ resource.name.path.o }}.actions';
import { {{ resource.name.pascal.o }}Table } from '@/lib/components/{% for part in resource.path %}{{ part }}/{% endfor %}{{ resource.name.path.o }}/{{ resource.name.path.o }}-table';
{% if ui.create %}
import { {{ ui.create.name.pascal.o }}Dialog } from '@/lib/components/{% for part in resource.path %}{{ part }}/{% endfor %}{{ resource.name.path.o }}/{{ resource.name.path.o }}-dialogs';
{% endif %}

{% if ui.list.meta.has_path_params %}
type {{ resource.name.pascal.o }}PageProps = {
{{ params_props(ui.list) }}
};
{% endif %}

export async function {{ resource.name.pascal.o }}Page{% if ui.list.meta.has_path_params %}(props: {{ resource.name.pascal.o }}PageProps){% else %}(){% endif %} {
  const result = await {{ ui.list.lang.function_name }}({
{{ params_object(ui.list) }}
  });
  const data = ((result.body as Record<string, unknown> | undefined)?.{{ ui.list.meta.ui_list_field }} ?? []) as never[];

  return (
    <div className="grid gap-4">
      <div className="flex items-center justify-between gap-3">
        <div>
          <h1 className="text-2xl font-semibold">{{ resource.name.pascal.o }}</h1>
          <p className="text-sm text-muted-foreground">Manage {{ resource.name.path.o }} records.</p>
        </div>
{% if ui.create %}
        <{{ ui.create.name.pascal.o }}Dialog
{% for param in ui.create.meta.path_params %}
          {{ param }}={props.{{ param }}}
{% endfor %}
        />
{% endif %}
      </div>
      <{{ resource.name.pascal.o }}Table data={data} />
    </div>
  );
}
{% else %}
export function {{ resource.name.pascal.o }}Page() {
  return null;
}
{% endif %}
