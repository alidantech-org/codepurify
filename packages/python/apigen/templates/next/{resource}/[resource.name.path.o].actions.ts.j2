{%- macro endpoint_expr(operation) -%}
{%- if operation.meta.has_path_params -%}
routes.{{ resource.name.camel.o }}.{{ operation.lang.function_name }}(input.params)
{%- else -%}
routes.{{ resource.name.camel.o }}.{{ operation.lang.function_name }}
{%- endif -%}
{%- endmacro %}

{%- macro response_type(operation) -%}
{{ operation.meta.response_type or 'unknown' }}
{%- endmacro %}

{%- macro form_action_result_type(operation) -%}
{{ operation.name.pascal.o }}ActionResult
{%- endmacro %}

{%- macro form_action_function_name(operation) -%}
{{ operation.lang.function_name }}Action
{%- endmacro %}

{%- macro resource_title() -%}
{{ resource.name.pascal.o if resource.name.pascal is defined else (resource.name.path.o | replace("_", " ") | replace("-", " ") | title | replace(" ", "")) }}
{%- endmacro %}

{%- set ns = namespace(has_form_actions=False, has_form_action_path_params=False, has_clean_form_actions=False) %}
{% for operation in resource.operations %}
{% if operation.meta.ui_enabled | default(false) and operation.meta.ui_role in ("create", "update", "auth") and operation.meta.body_type %}
{% set ns.has_form_actions = True %}
{% if operation.meta.has_path_params %}
{% set ns.has_form_action_path_params = True %}
{% endif %}
{% if not operation.meta.is_multipart_request %}
{% set ns.has_clean_form_actions = True %}
{% endif %}
{% endif %}
{% endfor -%}

'use server';

/**
 * ---------------------------------------------------------------------------
 * {{ resource_title() }} Server Actions
 * ---------------------------------------------------------------------------
 *
 * Generated request helpers for the {{ resource.name.camel.o }} resource.
 * Form-enabled operations also receive useActionState-compatible wrappers.
 */

import type {
{% if ns.has_form_actions %}
  ApiBridgeResponse,
{% endif %}
  RequestOptions,
} from 'next-api-bridge';
{% if ns.has_form_actions %}
import { redirect } from 'next/navigation';
{% endif %}
import { api } from '../api';
import routes from '../routes';
import {
{% if ns.has_form_actions %}
{% if ns.has_form_action_path_params %}
  actionFormDataValue,
{% endif %}
{% if ns.has_clean_form_actions %}
  cleanActionFormData,
{% endif %}
  formActionRedirectPath,
  type FormActionResult,
{% endif %}
  requestOptions,
} from './helpers';
{% for import in file.imports %}
{{ import.statement }}
{% endfor %}

{% for operation in resource.operations %}
{{ "\n" }}
/**
 * ---------------------------------------------------------------------------
 * {{ operation.name.pascal.o }}
 * ---------------------------------------------------------------------------
 *
 * @description Server action for the {{ operation.lang.function_name }} operation on the {{ resource.name.camel.o }} resource.
 *
 * @remarks
 * Method: {{ operation.lang.method | upper }}
{% if operation.meta.has_path_params %}
 * Params:
{% for param in operation.meta.path_params %}
 *   - {{ param }}: string
{% endfor %}
{% endif %}
{% if operation.meta.query_type %}
 * Query: {{ operation.meta.query_type }} (optional)
{% endif %}
{% if operation.meta.is_multipart_request %}
 * Body: FormData (multipart)
{% elif operation.meta.body_type %}
 * Body: {{ operation.meta.body_type }}{{ "" if operation.request_body and operation.request_body.lang.required else " (optional)" }}
{% endif %}
 *
 * @param input - {{ operation.name.pascal.o }}Input
 * @returns Promise<ApiBridgeResponse<{{ response_type(operation) }}>>
 */
type {{ operation.name.pascal.o }}Input = {
{% if operation.meta.has_path_params %}
  params: {
{% for param in operation.meta.path_params %}
    {{ param }}: string;
{% endfor %}
  };
{% endif %}
{% if operation.meta.query_type %}
  query?: {{ operation.meta.query_type }};
{% endif %}
{% if operation.meta.is_multipart_request %}
  body: FormData;
{% elif operation.meta.body_type %}
  body{% if operation.request_body and operation.request_body.lang.required %}{% else %}?{% endif %}: {{ operation.meta.body_type }};
{% endif %}
  options?: RequestOptions;
};

export async function {{ operation.lang.function_name }}(
  input: {{ operation.name.pascal.o }}Input{% if not operation.meta.has_path_params and not (operation.meta.body_type and operation.request_body and operation.request_body.lang.required) and not operation.meta.is_multipart_request %} = {}{% endif %},
) {
  const endpoint = {{ endpoint_expr(operation) }};
  const options = requestOptions(
    input?.options,
{% if operation.meta.query_type %}
    input?.query as Record<string, unknown>,
{% else %}
    undefined,
{% endif %}
    {{ "true" if operation.meta.is_multipart_request else "false" }},
  );
{% if operation.lang.method == 'get' %}

  return api.get<{{ response_type(operation) }}>(endpoint, options);
{% elif operation.meta.is_multipart_request %}

  return api.{{ operation.lang.method }}<{{ response_type(operation) }}>(endpoint, input.body, options);
{% elif operation.meta.body_type %}
  const body = input.body ? input.body : undefined;

  return api.{{ operation.lang.method }}<{{ response_type(operation) }}>(endpoint, body, options);
{% else %}

  return api.{{ operation.lang.method }}<{{ response_type(operation) }}>(endpoint, undefined, options);
{% endif %}
}

{% if operation.meta.ui_enabled | default(false) and operation.meta.ui_role in ("create", "update", "auth") and operation.meta.body_type %}

/**
 * {{ operation.name.pascal.o }} Action Result
 *
 * Typed result returned by the generated form action wrapper.
 */
type {{ form_action_result_type(operation) }} = FormActionResult<
{% if operation.meta.is_multipart_request %}
  FormData,
{% else %}
  {{ operation.meta.body_type }},
{% endif %}
  ApiBridgeResponse<{{ response_type(operation) }}>
>;

/**
 * {{ operation.name.pascal.o }} Form Action
 *
 * Cleans FormData controls, calls {{ operation.lang.function_name }}, and
 * redirects when __redirect_path is present and the response succeeds.
 */
export async function {{ form_action_function_name(operation) }}(
  _prev: {{ form_action_result_type(operation) }} | null,
  data: FormData,
): Promise<{{ form_action_result_type(operation) }}> {
  const redirectPath = formActionRedirectPath(data);
{% if operation.meta.is_multipart_request %}
  const body = data;
{% else %}
  const body = cleanActionFormData<{{ operation.meta.body_type }}>(
    data,
  );
{% endif %}

  const response = await {{ operation.lang.function_name }}({
{% if operation.meta.has_path_params %}
    params: {
{% for param in operation.meta.path_params %}
      {{ param }}: actionFormDataValue(data, '__path:{{ param }}'),
{% endfor %}
    },
{% endif %}
    body,
    options: {},
  });

  if (response.success && redirectPath) {
    redirect(redirectPath);
  }

  return { response, formdata: body };
}
{% endif %}
{% endfor %}
