{
      "name": "@codepurify/openapi-ts",
      "version": "0.0.1",
      "description": "Typed OpenAPI contract engine for TypeScript projects.",
      "type": "module",
      "main": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "exports": {
            ".": {
                  "types": "./dist/index.d.ts",
                  "import": "./dist/index.js"
            }
      },
      "files": [
            "dist",
            "README.md"
      ],
      "scripts": {
            "build": "tsc -p tsconfig.json",
            "clean": "rm -rf dist",
            "typecheck": "tsc -p tsconfig.json --noEmit"
      },
      "dependencies": {
            "@apidevtools/swagger-parser": "^10.1.1",
            "js-yaml": "^4.1.0",
            "zod": "^4.0.0"
      },
      "devDependencies": {
            "@types/js-yaml": "^4.0.9",
            "@types/node": "^22.0.0",
            "typescript": "^5.0.0"
      },
      "peerDependencies": {
            "zod": "^4.0.0"
      }
}