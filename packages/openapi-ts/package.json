{
      "name": "@codepurify/openapi-ts",
      "version": "0.0.1",
      "description": "Typed OpenAPI contract engine for TypeScript projects.",
      "type": "module",
      "main": "./dist/index.cjs",
      "module": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "exports": {
            ".": {
                  "import": {
                        "types": "./dist/index.d.ts",
                        "default": "./dist/index.js"
                  },
                  "require": {
                        "types": "./dist/index.d.cts",
                        "default": "./dist/index.cjs"
                  }
            }
      },
      "files": [
            "dist",
            "README.md"
      ],
      "scripts": {
            "dev": "tsup --watch && npm link",
            "build": "tsup && npm link",
            "clean": "rm -rf dist",
            "typecheck": "tsc -p tsconfig.json --noEmit",
            "dev:build": "npm run clean && npm run build"
      },
      "dependencies": {
            "@apidevtools/swagger-parser": "^10.1.1",
            "js-yaml": "^4.1.0",
            "tsx": "^4.22.3",
            "zod": "^4.0.0"
      },
      "devDependencies": {
            "@types/js-yaml": "^4.0.9",
            "@types/node": "^22.0.0",
            "tsup": "^8.0.0",
            "typescript": "^5.0.0"
      },
      "peerDependencies": {
            "zod": "^4.0.0"
      },
      "bin": {
            "openapi-ts": "./dist/cli/index.js"
      }
}