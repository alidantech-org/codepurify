Model Fields
============

Model: {{ model.name.pascal }}

{%- for field in model.fields %}
{{ loop.index }}. {{ field.name.camel }}
   API:
     Required: {{ field.api.required }}
     Nullable: {{ field.api.nullable }}
     Schema Ref: {{ field.api.schema_ref or "-" }}
     Item Ref: {{ field.api.item_ref or "-" }}
   Type:
     Kind: {{ field.api.type.kind }}
     Type: {{ field.api.type.type or "-" }}
     Format: {{ field.api.type.resolved_format or "-" }}
     Item Kind: {{ field.api.type.item_kind }}
     Item Type: {{ field.api.type.item_type or "-" }}
   Query:
     Enabled: {{ field.api.query.enabled }}
     Filterable: {{ field.api.query.filterable }}
     Sortable: {{ field.api.query.sortable }}
     Selectable: {{ field.api.query.selectable }}
     Searchable: {{ field.api.query.searchable }}
     Operators: {{ field.api.query.operators | join(", ") if field.api.query.operators else "-" }}
   Dependencies:
{%- for dependency in field.emit.dependencies %}
     - Ref: {{ dependency.ref }}
       Purpose: {{ dependency.purpose }}
       Reason: {{ dependency.reason }}
       Target Kind: {{ dependency.target.kind if dependency.target else "-" }}
       Is Primitive: {{ dependency.target.is_primitive if dependency.target else false }}
       Importable: {{ dependency.is_importable }}
{%- else %}
     - none
{%- endfor %}

{%- else %}
No fields.
{%- endfor %}
