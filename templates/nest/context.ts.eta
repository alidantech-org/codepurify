 */
export function get<%= entity.names.pascal %>UpdatableFields(): (keyof <%= entity.exports.interfaceName %>)[] {
  return [<% fields.mutation.updatable.forEach(field => { %>'<%= field.name %>',<% }) %>];
}

/**
 * Create empty <%= entity.names.camel.toLowerCase() %> entity
 */
export function createEmpty<%= entity.names.pascal %>(): Partial<<%= entity.exports.interfaceName %>> {
  return {
<% fields.groups.all.forEach(field => { %>
    <%= field.name %>: undefined,
<% }) %>
  };
}

/**
 * Create <%= entity.names.camel.toLowerCase() %> entity with default values
 */
export function createDefault<%= entity.names.pascal %>(): Partial<<%= entity.exports.interfaceName %>> {
  return {
<% fields.groups.all.forEach(field => { %>
    <%= field.name %>: <%= field.nullable ? 'null' : (field.type === 'string' ? "''" : (field.type === 'number' ? '0' : (field.type === 'boolean' ? 'false' : 'undefined'))) %>,
<% }) %>
  };
}

/**
 * Export all context types and utilities
 */
export type {
  <%= entity.generated.relationKeyType %>,
  <%= entity.generated.selectableFieldType %>,
  <%= entity.generated.sortableFieldType %>,
  <%= entity.generated.filterableFieldType %>,
  <%= entity.generated.creatableFieldType %>,
  <%= entity.generated.updatableFieldType %>,
  <%= entity.generated.listQueryType %>,
  <%= entity.generated.itemQueryType %>,
  <%= entity.generated.createInputType %>,
  <%= entity.generated.updateInputType %>,
<% relations.queries.asOneQueries.forEach(query => { %>
  <%= query.typeName %>,
<% }) %>
<% relations.queries.asManyQueries.forEach(query => { %>
  <%= query.typeName %>,
<% }) %>
};

export {
  <%= entity.relationMaps.entityRelationsMap %>,
  <%= entity.relationMaps.relationTargetsMap %>,
  <%= entity.relationMaps.relationFieldsMap %>,
  <%= entity.names.camel %>Fields,
  <%= entity.names.camel %>FieldGroups,
  <%= entity.names.camel %>FieldSelection,
  <%= entity.names.camel %>FieldMutation,
};
