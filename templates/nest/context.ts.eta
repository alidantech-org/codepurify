}

/**
 * Utility functions for <%= entity.names.pascal %>
 */

/**
 * Get all <%= entity.names.camel.toLowerCase() %> field names
 */
export function get<%= entity.names.pascal %>FieldNames(): (keyof <%= entity.exports.interfaceName %>)[] {
  return [<% fields.groups.all.forEach(field => { %>'<%= field.name %>',<% }) %>];
}

/**
 * Get <%= entity.names.camel.toLowerCase() %> primary key fields
 */
export function get<%= entity.names.pascal %>PrimaryKeys(): (keyof <%= entity.exports.interfaceName %>)[] {
  return [<% fields.groups.primaryKeys.forEach(field => { %>'<%= field.name %>',<% }) %>];
}

/**
