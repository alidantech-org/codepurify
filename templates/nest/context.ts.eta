 */
export function get<%= entity.names.pascal %>CreatableFields(): (keyof <%= entity.exports.interfaceName %>)[] {
  return [<% fields.mutation.creatable.forEach(field => { %>'<%= field.name %>',<% }) %>];
}

/**
