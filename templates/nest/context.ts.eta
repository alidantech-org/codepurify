 * Check if a field is a foreign key
 */
export function is<%= entity.names.pascal %>ForeignKey(field: string): field is keyof <%= entity.exports.interfaceName %> {
  return [<% fields.groups.foreignKeys.forEach(field => { %>'<%= field.name %>',<% }) %>].includes(field);
}

