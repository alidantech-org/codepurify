 */
export const <%= entity.names.camel %>FieldMutation = {
  creatable: [<% fields.mutation.creatable.forEach(field => { %>'<%= field.name %>',<% }) %>],
  systemCreatable: [<% fields.mutation.systemCreatable.forEach(field => { %>'<%= field.name %>',<% }) %>],
  updatable: [<% fields.mutation.updatable.forEach(field => { %>'<%= field.name %>',<% }) %>],
  editable: [<% fields.mutation.editable.forEach(field => { %>'<%= field.name %>',<% }) %>],
  readonly: [<% fields.mutation.readonly.forEach(field => { %>'<%= field.name %>',<% }) %>],
  immutable: [<% fields.mutation.immutable.forEach(field => { %>'<%= field.name %>',<% }) %>],
} as const;

/**
 * Type guards for <%= entity.names.pascal %>
 */

/**
 * Check if a field is a primary key
 */
export function is<%= entity.names.pascal %>PrimaryKey(field: string): field is keyof <%= entity.exports.interfaceName %> {
  return [<% fields.groups.primaryKeys.forEach(field => { %>'<%= field.name %>',<% }) %>].includes(field);
}

