{
  "name": "Codepurify",
  "scopeName": "source.codepurify",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#blocks"
    },
    {
      "include": "#expressions"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.block.documentation.codepurify",
          "begin": "\\{!*\\*",
          "end": "\\*~\\)"
        },
        {
          "name": "comment.block.codepurify",
          "begin": "\\{!*#",
          "end": "#~\\)"
        }
      ]
    },
    "blocks": {
      "patterns": [
        {
          "name": "meta.block.codepurify",
          "begin": "\\{!*\\s*(if|loop|raw|unless|with)\\b",
          "beginCaptures": {
            "0": {
              "name": "meta.tag.template.begin.codepurify"
            },
            "1": {
              "name": "keyword.control.codepurify"
            }
          },
          "end": "~\\)",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.template.end.codepurify"
            }
          },
          "patterns": [
            {
              "include": "#operators"
            },
            {
              "include": "#literals"
            },
            {
              "include": "#aliases"
            },
            {
              "include": "#variables"
            },
            {
              "include": "#keywords"
            }
          ]
        }
      ]
    },
    "expressions": {
      "patterns": [
        {
          "name": "meta.expression.codepurify",
          "begin": "\\{!*",
          "end": "~\\)",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.template.begin.codepurify"
            }
          },
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.template.end.codepurify"
            }
          },
          "patterns": [
            {
              "include": "#keywords"
            },
            {
              "include": "#operators"
            },
            {
              "include": "#literals"
            },
            {
              "include": "#aliases"
            },
            {
              "include": "#variables"
            },
            {
              "include": "#properties"
            }
          ]
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.conditional.codepurify",
          "match": "\\b(if|else|unless|with|raw)\\b"
        },
        {
          "name": "keyword.control.repeat.codepurify",
          "match": "\\b(loop|for)\\b"
        },
        {
          "name": "keyword.control.end.codepurify",
          "match": "\\b(/if|/loop|/for|/raw|/unless|/with)\\b"
        },
        {
          "name": "keyword.operator.word.codepurify",
          "match": "\\b(as|in|not|and|or|is)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.codepurify",
          "match": "(==|!=|<=|>=|<|>|!)"
        },
        {
          "name": "keyword.operator.logical.codepurify",
          "match": "(&&|\\|\\|)"
        }
      ]
    },
    "literals": {
      "patterns": [
        {
          "name": "constant.language.boolean.codepurify",
          "match": "\\b(true|false|null|undefined)\\b"
        },
        {
          "name": "constant.numeric.codepurify",
          "match": "\\b\\d+(\\.\\d+)?\\b"
        },
        {
          "name": "string.quoted.single.codepurify",
          "begin": "'",
          "end": "'"
        },
        {
          "name": "string.quoted.double.codepurify",
          "begin": "\"",
          "end": "\""
        }
      ]
    },
    "aliases": {
      "patterns": [
        {
          "name": "variable.parameter.alias.codepurify",
          "match": "(?<=\\bas\\s+)[a-zA-Z_$][a-zA-Z0-9_$]*"
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "name": "variable.language.root.codepurify",
          "match": "\\b(entity|global|resource|field|relation|template|item|index)\\b"
        },
        {
          "name": "variable.other.path.codepurify",
          "match": "\\b[a-zA-Z_$][a-zA-Z0-9_$]*(\\.[a-zA-Z_$][a-zA-Z0-9_$]*)+\\b"
        },
        {
          "name": "variable.other.identifier.codepurify",
          "match": "\\b[a-zA-Z_$][a-zA-Z0-9_$]*\\b"
        }
      ]
    },
    "properties": {
      "patterns": [
        {
          "name": "support.type.namespace.codepurify",
          "match": "\\b(arrays|flags|counts|maps|names|casing|items|length)\\b"
        },
        {
          "name": "support.constant.casing.codepurify",
          "match": "\\b(camel|pascal|snake|kebab|constant|dot|slash|path|lower|upper|title|train)\\b"
        }
      ]
    }
  }
}