{[# JavaScript example #]}

const {[entity.name.camel]} = {
  {[loop field in entity.fields]}
  {[field.name.camel]}: {[field.type]},
  {[/loop]}
};

export default {[entity.name.camel]};

{
  "{[entity.name.camel]}": {
    {[loop field in entity.fields]}
    "{[field.name.camel]}": "{[field.type]}",
    {[/loop]}
  }
}
