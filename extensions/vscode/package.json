    ],
    "grammars": [
      {
        "language": "codepurify",
        "scopeName": "source.codepurify",
        "path": "./syntaxes/codepurify.tmLanguage.json"
      },
      {
        "language": "codepurify-javascript",
        "scopeName": "source.js.codepurify",
        "path": "./syntaxes/wrappers/codepurify-javascript.tmLanguage.json"
      },
      {
        "language": "codepurify-jsx",
        "scopeName": "source.jsx.codepurify",
        "path": "./syntaxes/wrappers/codepurify-jsx.tmLanguage.json"
      },
      {
        "language": "codepurify-typescript",
        "scopeName": "source.ts.codepurify",
        "path": "./syntaxes/wrappers/codepurify-typescript.tmLanguage.json"
      },
      {
        "language": "codepurify-tsx",
        "scopeName": "source.tsx.codepurify",
        "path": "./syntaxes/wrappers/codepurify-tsx.tmLanguage.json"
      },
      {
        "language": "codepurify-sql",
        "scopeName": "source.sql.codepurify",
        "path": "./syntaxes/wrappers/codepurify-sql.tmLanguage.json"
      },
      {
        "language": "codepurify-java",
        "scopeName": "source.java.codepurify",
        "path": "./syntaxes/wrappers/codepurify-java.tmLanguage.json"
      },
      {
        "language": "codepurify-go",
        "scopeName": "source.go.codepurify",
