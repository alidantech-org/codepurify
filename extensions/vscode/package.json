{
  "name": "codepurify-templates",
  "displayName": "Codepurify Templates",
  "version": "0.0.1",
  "description": "Template language support for deterministic Codepurify code generation with syntax highlighting, autocomplete, hover documentation, and validation.",
  "publisher": "alidantechorg",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "codepurify",
    "code generation",
    "templates",
    "syntax highlighting",
    "autocomplete"
  ],
  "author": "alidantech.org",
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/alidantech-org/codepurify.git"
  },
  "main": "./out/extension.js",
  "activationEvents": [],
  "contributes": {
    "languages": [
      {
        "id": "codepurify",
        "aliases": [
          "Codepurify",
          "codepurify"
        ],
        "extensions": [
          ".codepurify",
          ".code"
        ],
        "configuration": "./config/language-configuration.json"
      },
      {
        "id": "codepurify-javascript",
        "aliases": [
          "Codepurify JavaScript"
        ],
        "extensions": [
          ".js.codepurify",
          ".js.code"
        ],
        "configuration": "./config/language-configuration.json"
      },
      {
