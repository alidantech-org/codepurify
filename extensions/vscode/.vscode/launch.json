{
      "version": "0.2.0",
      "configurations": [
            {
                  "args": [
                        "--extensionDevelopmentPath=${workspaceFolder}"
                  ],
                  "name": "Launch Extension",
                  "outFiles": [
                        "${workspaceFolder}/out/**/*.js"
                  ],
                  "preLaunchTask": "npm",
                  "request": "launch",
                  "type": "extensionHost"
            },
            {
                  "name": "Run Codepurify Extension",
                  "type": "extensionHost",
                  "request": "launch",
                  "args": [
                        "--folder-uri=${workspaceFolder}"
                  ]
            }
      ]
}