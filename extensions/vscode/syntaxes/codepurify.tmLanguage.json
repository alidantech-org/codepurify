{
  "name": "Codepurify",
  "scopeName": "source.codepurify",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#blocks"
    },
    {
      "include": "#expressions"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.block.documentation.codepurify",
          "begin": "\\{!\\*",
          "end": "\\*!\\}"
        },
        {
          "name": "comment.block.codepurify",
          "begin": "\\{!#",
          "end": "#!\\}"
        }
      ]
    },
    "blocks": {
      "patterns": [
        {
          "name": "meta.block.codepurify",
          "begin": "\\{!\\s*(if|loop|raw|unless|with)\\b",
          "beginCaptures": {
            "0": {
              "name": "meta.tag.template.begin.codepurify"
            },
            "1": {
              "name": "keyword.control.codepurify"
            }
          },
          "end": "!\\}",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.template.end.codepurify"
            }
          },
          "patterns": [
            {
              "include": "#keywords"
            },
            {
              "include": "#operators"
            },
            {
              "include": "#literals"
            },
            {
              "include": "#aliases"
            },
            {
              "include": "#properties"
            },
            {
              "include": "#variables"
            }
          ]
        }
      ]
    },
    "expressions": {
      "patterns": [
        {
          "name": "meta.expression.codepurify",
          "begin": "\\{!",
          "end": "!\\}",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.template.begin.codepurify"
            }
          },
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.template.end.codepurify"
            }
          },
          "patterns": [
            {
              "include": "#keywords"
            },
            {
              "include": "#operators"
            },
            {
              "include": "#literals"
            },
            {
              "include": "#aliases"
            },
            {
              "include": "#properties"
            },
            {
              "include": "#variables"
            }
          ]
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.conditional.codepurify",
          "match": "\\b(if|else|unless|with|raw)\\b"
        },
        {
          "name": "keyword.control.repeat.codepurify",
          "match": "\\b(loop|for)\\b"
        },
        {
          "name": "keyword.control.end.codepurify",
          "match": "\\/(if|loop|for|raw|unless|with)\\b"
        },
        {
          "name": "keyword.operator.word.codepurify",
          "match": "\\b(as|in|not|and|or|is)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.codepurify",
          "match": "(==|!=|<=|>=|<|>|!)"
        },
        {
          "name": "keyword.operator.logical.codepurify",
          "match": "(&&|\\|\\|)"
        }
      ]
    },
    "literals": {
      "patterns": [
        {
          "name": "constant.language.boolean.codepurify",
          "match": "\\b(true|false|null|undefined)\\b"
        },
        {
          "name": "constant.numeric.codepurify",
          "match": "\\b\\d+(\\.\\d+)?\\b"
        },
        {
          "name": "string.quoted.single.codepurify",
          "begin": "'",
          "end": "'"
        },
        {
          "name": "string.quoted.double.codepurify",
          "begin": "\"",
          "end": "\""
        }
      ]
    },
    "aliases": {
      "patterns": [
        {
          "name": "variable.parameter.alias.codepurify",
          "match": "(?<=\\bas\\s+)[a-zA-Z_$][a-zA-Z0-9_$]*"
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "name": "variable.other.path.entity.codepurify",
          "match": "\\bentity\\.[a-zA-Z_$][a-zA-Z0-9_$]*(\\.[a-zA-Z_$][a-zA-Z0-9_$]*)*\\b"
        },
        {
          "name": "variable.other.path.field.codepurify",
          "match": "\\bfield\\.[a-zA-Z_$][a-zA-Z0-9_$]*(\\.[a-zA-Z_$][a-zA-Z0-9_$]*)*\\b"
        },
        {
          "name": "variable.other.path.relation.codepurify",
          "match": "\\brelation\\.[a-zA-Z_$][a-zA-Z0-9_$]*(\\.[a-zA-Z_$][a-zA-Z0-9_$]*)*\\b"
        },
        {
          "name": "variable.other.path.global.codepurify",
          "match": "\\bglobal\\.[a-zA-Z_$][a-zA-Z0-9_$]*(\\.[a-zA-Z_$][a-zA-Z0-9_$]*)*\\b"
        },
        {
          "name": "variable.other.path.codepurify",
          "match": "\\b[a-zA-Z_$][a-zA-Z0-9_$]*(\\.[a-zA-Z_$][a-zA-Z0-9_$]*)+\\b"
        },
        {
          "name": "variable.language.root.entity.codepurify",
          "match": "\\bentity\\b"
        },
        {
          "name": "variable.language.root.field.codepurify",
          "match": "\\bfield\\b"
        },
        {
          "name": "variable.language.root.relation.codepurify",
          "match": "\\brelation\\b"
        },
        {
          "name": "variable.language.root.global.codepurify",
          "match": "\\bglobal\\b"
        },
        {
          "name": "variable.language.root.resource.codepurify",
          "match": "\\bresource\\b"
        },
        {
          "name": "variable.language.root.template.codepurify",
          "match": "\\btemplate\\b"
        },
        {
          "name": "variable.language.root.item.codepurify",
          "match": "\\b(item|index)\\b"
        },
        {
          "name": "variable.other.identifier.codepurify",
          "match": "\\b[a-zA-Z_$][a-zA-Z0-9_$]*\\b"
        }
      ]
    },
    "properties": {
      "patterns": [
        {
          "name": "support.type.namespace.name.codepurify",
          "match": "\\bname\\b"
        },
        {
          "name": "support.type.namespace.casing.codepurify",
          "match": "\\bcasing\\b"
        },
        {
          "name": "support.type.namespace.validation.codepurify",
          "match": "\\bvalidation\\b"
        },
        {
          "name": "support.type.namespace.array.codepurify",
          "match": "\\barray\\b"
        },
        {
          "name": "support.type.namespace.flags.codepurify",
          "match": "\\bflags\\b"
        },
        {
          "name": "support.type.namespace.counts.codepurify",
          "match": "\\bcounts\\b"
        },
        {
          "name": "support.type.namespace.maps.codepurify",
          "match": "\\bmaps\\b"
        },
        {
          "name": "support.type.namespace.items.codepurify",
          "match": "\\bitems\\b"
        },
        {
          "name": "support.property.length.codepurify",
          "match": "\\blength\\b"
        },
        {
          "name": "support.property.original.codepurify",
          "match": "\\boriginal\\b"
        },
        {
          "name": "support.constant.casing.camel.codepurify",
          "match": "\\bcamel\\b"
        },
        {
          "name": "support.constant.casing.pascal.codepurify",
          "match": "\\bpascal\\b"
        },
        {
          "name": "support.constant.casing.snake.codepurify",
          "match": "\\bsnake\\b"
        },
        {
          "name": "support.constant.casing.kebab.codepurify",
          "match": "\\bkebab\\b"
        },
        {
          "name": "support.constant.casing.constant.codepurify",
          "match": "\\bconstant\\b"
        },
        {
          "name": "support.constant.casing.dot.codepurify",
          "match": "\\bdot\\b"
        },
        {
          "name": "support.constant.casing.slash.codepurify",
          "match": "\\bslash\\b"
        },
        {
          "name": "support.constant.casing.path.codepurify",
          "match": "\\bpath\\b"
        },
        {
          "name": "support.constant.casing.lower.codepurify",
          "match": "\\blower\\b"
        },
        {
          "name": "support.constant.casing.upper.codepurify",
          "match": "\\bupper\\b"
        },
        {
          "name": "support.constant.casing.title.codepurify",
          "match": "\\btitle\\b"
        },
        {
          "name": "support.constant.casing.train.codepurify",
          "match": "\\btrain\\b"
        },
        {
          "name": "support.property.rules.codepurify",
          "match": "\\brules\\b"
        },
        {
          "name": "support.property.type.codepurify",
          "match": "\\btype\\b"
        },
        {
          "name": "support.property.required.codepurify",
          "match": "\\brequired\\b"
        }
      ]
    },
    "template-content": {
      "patterns": [
        {
          "include": "#keywords"
        },
        {
          "include": "#operators"
        },
        {
          "include": "#literals"
        },
        {
          "include": "#aliases"
        },
        {
          "include": "#properties"
        },
        {
          "include": "#variables"
        }
      ]
    }
  }
}