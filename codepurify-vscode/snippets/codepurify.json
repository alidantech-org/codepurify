{
      "Name Original": {
            "prefix": "name.original",
            "body": [
                  "(~ ${1:entity}.names.original ~)"
            ],
            "description": "Original source name"
      },
      "Name Length": {
            "prefix": "name.length",
            "body": [
                  "(~ ${1:entity}.names.length ~)"
            ],
            "description": "Original name length"
      },
      "Name Casing": {
            "prefix": "name.casing",
            "body": [
                  "(~ ${1:entity}.names.casing.${2|camel,pascal,snake,kebab,dot,slash,path,constant,lower,upper,title,train|} ~)"
            ],
            "description": "Any casing variant"
      },
      "Entity Casing": {
            "prefix": "entity.name",
            "body": [
                  "(~ entity.names.casing.${1|camel,pascal,snake,kebab,dot,slash,path,constant,lower,upper,title,train|} ~)"
            ],
            "description": "Entity casing variant"
      },
      "Field Casing": {
            "prefix": "field.name",
            "body": [
                  "(~ field.names.casing.${1|camel,pascal,snake,kebab,dot,slash,path,constant,lower,upper,title,train|} ~)"
            ],
            "description": "Field casing variant"
      },
      "Relation Casing": {
            "prefix": "relation.name",
            "body": [
                  "(~ relation.names.casing.${1|camel,pascal,snake,kebab,dot,slash,path,constant,lower,upper,title,train|} ~)"
            ],
            "description": "Relation casing variant"
      },
      "Module Casing": {
            "prefix": "module.name",
            "body": [
                  "(~ ${1:relation}.module.names.casing.${2|camel,pascal,snake,kebab,dot,slash,path,constant,lower,upper,title,train|} ~)"
            ],
            "description": "Module casing variant"
      },
      "Property Casing": {
            "prefix": "property.name",
            "body": [
                  "(~ ${1:relation}.property.names.casing.${2|camel,pascal,snake,kebab,dot,slash,path,constant,lower,upper,title,train|} ~)"
            ],
            "description": "Property casing variant"
      },
      "Singular Casing": {
            "prefix": "name.singular",
            "body": [
                  "(~ ${1:entity}.names.singular.casing.${2|camel,pascal,snake,kebab,dot,slash,path,constant,lower,upper,title,train|} ~)"
            ],
            "description": "Singular name casing variant"
      },
      "Plural Casing": {
            "prefix": "name.plural",
            "body": [
                  "(~ ${1:entity}.names.plural.casing.${2|camel,pascal,snake,kebab,dot,slash,path,constant,lower,upper,title,train|} ~)"
            ],
            "description": "Plural name casing variant"
      },
      "Each Name Parts": {
            "prefix": "each.name.parts",
            "body": [
                  "(~ each ${1:entity}.names.arrays.parts.items as part ~)",
                  "  (~ part.casing.${2|camel,pascal,snake,kebab,dot,slash,path,constant,lower,upper,title,train|} ~)",
                  "(~ /each ~)"
            ],
            "description": "Loop over name parts"
      },
      "Each Name Words": {
            "prefix": "each.name.words",
            "body": [
                  "(~ each ${1:entity}.names.arrays.words.items as word ~)",
                  "  (~ word.casing.${2|camel,pascal,snake,kebab,dot,slash,path,constant,lower,upper,title,train|} ~)",
                  "(~ /each ~)"
            ],
            "description": "Loop over name words"
      },
      "Each Name Characters": {
            "prefix": "each.name.characters",
            "body": [
                  "(~ each ${1:entity}.names.arrays.characters.items as character ~)",
                  "  (~ character.casing.${2|camel,pascal,snake,kebab,dot,slash,path,constant,lower,upper,title,train|} ~)",
                  "(~ /each ~)"
            ],
            "description": "Loop over name characters"
      },
      "Array Length": {
            "prefix": "array.length",
            "body": [
                  "(~ ${1:entity.fields.arrays.all}.length ~)"
            ],
            "description": "Array child length"
      },
      "Array Items Loop": {
            "prefix": "each.array",
            "body": [
                  "(~ each ${1:entity.fields.arrays.all.items} as ${2:item} ~)",
                  "  $0",
                  "(~ /each ~)"
            ],
            "description": "Loop over any ArrayChildContext items"
      },
      "Item Index": {
            "prefix": "item.index",
            "body": [
                  "(~ ${1:item}.index ~)"
            ],
            "description": "Current array item index"
      },
      "Each Fields": {
            "prefix": "each.fields",
            "body": [
                  "(~ each entity.fields.arrays.all.items as field ~)",
                  "  $0",
                  "(~ /each ~)"
            ],
            "description": "Loop over all entity fields"
      },
      "Each Relations": {
            "prefix": "each.relations",
            "body": [
                  "(~ each entity.relations.arrays.all.items as relation ~)",
                  "  $0",
                  "(~ /each ~)"
            ],
            "description": "Loop over all entity relations"
      },
      "If Block": {
            "prefix": "if",
            "body": [
                  "(~ if ${1:condition} ~)",
                  "  $0",
                  "(~ /if ~)"
            ],
            "description": "Codepurify if block"
      },
      "If Else Block": {
            "prefix": "ifelse",
            "body": [
                  "(~ if ${1:condition} ~)",
                  "  ${2:if_content}",
                  "(~ else ~)",
                  "  $0",
                  "(~ /if ~)"
            ],
            "description": "Codepurify if/else block"
      },
      "Comment": {
            "prefix": "cp.comment",
            "body": [
                  "(~# ${1:comment} #~)"
            ],
            "description": "Codepurify comment"
      },
      "Raw Block": {
            "prefix": "raw",
            "body": [
                  "(~ raw ~)",
                  "$0",
                  "(~ /raw ~)"
            ],
            "description": "Raw block"
      }
}