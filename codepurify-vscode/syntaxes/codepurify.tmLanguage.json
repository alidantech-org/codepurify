{
  "name": "Codepurify",
  "scopeName": "source.codepurify",
  "patterns": [
    {
      "include": "#comment"
    },
    {
      "include": "#expression"
    }
  ],
  "repository": {
    "comment": {
      "patterns": [
        {
          "name": "comment.block.codepurify",
          "begin": "\\(~#",
          "end": "#~\\)"
        }
      ]
    },
    "expression": {
      "patterns": [
        {
          "name": "meta.expression.codepurify",
          "begin": "\\(~",
          "end": "~\\)",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.template.begin.codepurify"
            }
          },
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.template.end.codepurify"
            }
          },
          "patterns": [
            {
              "include": "#keywords"
            },
            {
              "include": "#variables"
            }
          ]
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.codepurify",
          "match": "\\b(if|else|each|raw|\\/if|\\/each|\\/raw)\\b"
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "name": "variable.other.codepurify",
          "match": "[a-zA-Z_$][a-zA-Z0-9_$.]*"
        }
      ]
    }
  }
}